# 忽略操作系统临时文件
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# 忽略 Python 缓存
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/

# 忽略 Node.js 缓存
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# 忽略 IDE 配置
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# 忽略运行时日志与临时数据
*.log
*.tmp
*.bak
*.cache
.temp/

# 忽略 www 运行时产生的动态文件（仅保留源码）
www_memory/
www_logs/
www_state/

# 忽略敏感配置（含本地模型路径等）
local_config.json
.env
